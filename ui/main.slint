import { Button, VerticalBox, HorizontalBox, ListView, LineEdit, Switch, ComboBox, ScrollView } from "std-widgets.slint";

struct ReminderItem {
    id: int,
    title: string,
    content: string,
    enabled: bool,
    completed: bool,
    next-trigger: string,
}

export component MainWindow inherits Window {
    title: "due";
    icon: @image-url("../assets/icon.png");
    min-width: 800px;
    min-height: 500px;
    preferred-width: 960px;
    preferred-height: 600px;

    // 回调
    callback add-clicked(string, string, int);
    callback delete-clicked(int);
    callback toggle-enabled(int);
    callback select-reminder(int);
    callback save-clicked(int, string, string, int, string, string, string, string, string, string);

    // 列表数据
    in-out property <[ReminderItem]> reminders: [];
    in-out property <int> selected-index: -1;

    // 编辑面板字段
    in-out property <string> edit-title: "";
    in-out property <string> edit-content: "";
    in-out property <int> repeat-type-index: 0;
    in-out property <string> edit-start-date: "";
    in-out property <string> edit-end-date: "";
    in-out property <string> edit-daily-start: "";
    in-out property <string> edit-daily-end: "";
    in-out property <string> repeat-amount-value: "";
    in-out property <string> repeat-limit-value: "";

    // Fluent light 背景
    background: #f3f3f3;

    HorizontalLayout {
        spacing: 0px;

        // ── 左侧：侧边栏 ──
        Rectangle {
            width: 280px;
            background: #ffffff;
            clip: true;

            VerticalLayout {
                padding: 16px;
                spacing: 12px;

                // Logo
                Text {
                    text: "due";
                    font-size: 28px;
                    font-weight: 700;
                    color: #1a1a1a;
                    horizontal-alignment: left;
                }

                // 添加提醒
                HorizontalLayout {
                    spacing: 8px;
                    height: 32px;

                    new-title := LineEdit {
                        placeholder-text: "输入提醒...";
                        horizontal-stretch: 1;
                        font-size: 13px;
                    }

                    Button {
                        text: "+";
                        width: 32px;
                        clicked => {
                            if (new-title.text != "") {
                                root.add-clicked(new-title.text, "", 0);
                                new-title.text = "";
                            }
                        }
                    }
                }

                // 提醒列表
                ListView {
                    for item[id] in root.reminders: Rectangle {
                        height: 44px;
                        border-radius: 8px;
                        background: id == root.selected-index ? #e8f0fe : (ta.has-hover ? #f5f5f5 : transparent);

                        ta := TouchArea {
                            clicked => {
                                root.select-reminder(id);
                            }
                        }

                        HorizontalLayout {
                            padding-left: 0px;
                            padding-right: 12px;
                            spacing: 0px;
                            alignment: stretch;

                            // 选中指示条
                            Rectangle {
                                width: 3px;
                                height: 24px;
                                border-radius: 2px;
                                background: id == root.selected-index ? #0078d4 : transparent;
                                y: parent.height / 2 - self.height / 2;
                            }

                            // 状态指示点
                            Rectangle {
                                width: 8px;
                                height: 8px;
                                border-radius: 4px;
                                y: parent.height / 2 - self.height / 2;
                                background: item.completed ? #107c10 : (item.enabled ? #0078d4 : #9e9e9e);
                            }

                            VerticalLayout {
                                alignment: center;
                                spacing: 2px;
                                padding-left: 8px;

                                Text {
                                    text: item.title;
                                    font-size: 13px;
                                    font-weight: 600;
                                    color: item.completed ? #9e9e9e : #1a1a1a;
                                    overflow: elide;
                                }

                                Text {
                                    text: item.next-trigger;
                                    font-size: 11px;
                                    color: #616161;
                                    visible: item.next-trigger != "";
                                }
                            }
                        }
                    }
                }
            }
        }

        // ── 右侧：编辑面板 ──
        Rectangle {
            background: #f3f3f3;

            if root.selected-index >= 0 && root.selected-index < root.reminders.length: ScrollView {
                VerticalLayout {
                    padding: 24px;
                    spacing: 16px;

                    Text {
                        text: "编辑提醒";
                        font-size: 20px;
                        font-weight: 700;
                        color: #1a1a1a;
                    }

                    // ── 基础信息卡片 ──
                    Rectangle {
                        background: #ffffff;
                        border-radius: 8px;

                        VerticalLayout {
                            padding: 16px;
                            spacing: 12px;

                            Text {
                                text: "基础信息";
                                font-size: 13px;
                                font-weight: 600;
                                color: #616161;
                            }

                            VerticalLayout {
                                spacing: 4px;
                                Text {
                                    text: "标题";
                                    font-size: 11px;
                                    color: #9e9e9e;
                                }
                                edit-title-input := LineEdit {
                                    text: root.edit-title;
                                    height: 32px;
                                    font-size: 13px;
                                }
                            }

                            VerticalLayout {
                                spacing: 4px;
                                Text {
                                    text: "内容";
                                    font-size: 11px;
                                    color: #9e9e9e;
                                }
                                edit-content-input := LineEdit {
                                    text: root.edit-content;
                                    height: 32px;
                                    font-size: 13px;
                                }
                            }
                        }
                    }

                    // ── 重复设置卡片 ──
                    Rectangle {
                        background: #ffffff;
                        border-radius: 8px;

                        VerticalLayout {
                            padding: 16px;
                            spacing: 12px;

                            Text {
                                text: "重复设置";
                                font-size: 13px;
                                font-weight: 600;
                                color: #616161;
                            }

                            VerticalLayout {
                                spacing: 4px;
                                Text {
                                    text: "重复类型";
                                    font-size: 11px;
                                    color: #9e9e9e;
                                }
                                repeat-combo := ComboBox {
                                    model: ["不重复", "按分钟", "按小时", "按天"];
                                    current-index: root.repeat-type-index;
                                    selected => {
                                        root.repeat-type-index = self.current-index;
                                    }
                                }
                            }

                            if root.repeat-type-index > 0: VerticalLayout {
                                spacing: 4px;
                                Text {
                                    text: root.repeat-type-index == 1 ? "间隔（分钟）" : (root.repeat-type-index == 2 ? "间隔（小时）" : "间隔（天）");
                                    font-size: 11px;
                                    color: #9e9e9e;
                                }
                                repeat-amount-input := LineEdit {
                                    text: root.repeat-amount-value;
                                    placeholder-text: "例如: 30";
                                    height: 32px;
                                    font-size: 13px;
                                    input-type: number;
                                    edited => {
                                        root.repeat-amount-value = self.text;
                                    }
                                }
                            }

                            if root.repeat-type-index > 0: VerticalLayout {
                                spacing: 4px;
                                Text {
                                    text: "次数限制（留空不限）";
                                    font-size: 11px;
                                    color: #9e9e9e;
                                }
                                repeat-limit-input := LineEdit {
                                    text: root.repeat-limit-value;
                                    placeholder-text: "不限";
                                    height: 32px;
                                    font-size: 13px;
                                    input-type: number;
                                    edited => {
                                        root.repeat-limit-value = self.text;
                                    }
                                }
                            }
                        }
                    }

                    // ── 时间范围卡片 ──
                    Rectangle {
                        background: #ffffff;
                        border-radius: 8px;

                        VerticalLayout {
                            padding: 16px;
                            spacing: 12px;

                            Text {
                                text: "时间范围";
                                font-size: 13px;
                                font-weight: 600;
                                color: #616161;
                            }

                            HorizontalLayout {
                                spacing: 12px;

                                VerticalLayout {
                                    horizontal-stretch: 1;
                                    spacing: 4px;
                                    Text {
                                        text: "开始日期";
                                        font-size: 11px;
                                        color: #9e9e9e;
                                    }
                                    start-date-input := LineEdit {
                                        text: root.edit-start-date;
                                        placeholder-text: "2026-06-01";
                                        height: 32px;
                                        font-size: 13px;
                                    }
                                }

                                VerticalLayout {
                                    horizontal-stretch: 1;
                                    spacing: 4px;
                                    Text {
                                        text: "结束日期";
                                        font-size: 11px;
                                        color: #9e9e9e;
                                    }
                                    end-date-input := LineEdit {
                                        text: root.edit-end-date;
                                        placeholder-text: "2026-12-31";
                                        height: 32px;
                                        font-size: 13px;
                                    }
                                }
                            }

                            HorizontalLayout {
                                spacing: 12px;

                                VerticalLayout {
                                    horizontal-stretch: 1;
                                    spacing: 4px;
                                    Text {
                                        text: "每日开始";
                                        font-size: 11px;
                                        color: #9e9e9e;
                                    }
                                    daily-start-input := LineEdit {
                                        text: root.edit-daily-start;
                                        placeholder-text: "09:00";
                                        height: 32px;
                                        font-size: 13px;
                                    }
                                }

                                VerticalLayout {
                                    horizontal-stretch: 1;
                                    spacing: 4px;
                                    Text {
                                        text: "每日结束";
                                        font-size: 11px;
                                        color: #9e9e9e;
                                    }
                                    daily-end-input := LineEdit {
                                        text: root.edit-daily-end;
                                        placeholder-text: "18:00";
                                        height: 32px;
                                        font-size: 13px;
                                    }
                                }
                            }
                        }
                    }

                    // 弹性空白
                    Rectangle { vertical-stretch: 1; }

                    // 操作按钮
                    HorizontalLayout {
                        spacing: 8px;

                        Button {
                            text: "保存修改";
                            horizontal-stretch: 1;
                            clicked => {
                                root.save-clicked(
                                    root.selected-index,
                                    edit-title-input.text,
                                    edit-content-input.text,
                                    root.repeat-type-index,
                                    root.repeat-type-index > 0 ? root.repeat-amount-value : "",
                                    start-date-input.text,
                                    end-date-input.text,
                                    daily-start-input.text,
                                    daily-end-input.text,
                                    root.repeat-type-index > 0 ? root.repeat-limit-value : "",
                                );
                            }
                        }

                        Button {
                            text: "删除";
                            clicked => {
                                root.delete-clicked(root.selected-index);
                            }
                        }
                    }
                }
            }

            // 空状态
            if root.selected-index < 0 || root.selected-index >= root.reminders.length: VerticalLayout {
                alignment: center;
                spacing: 12px;

                Text {
                    text: "📋";
                    font-size: 48px;
                    horizontal-alignment: center;
                }
                Text {
                    text: "选择左侧提醒进行编辑";
                    font-size: 16px;
                    color: #616161;
                    horizontal-alignment: center;
                }
                Text {
                    text: "或在上方创建新提醒";
                    font-size: 13px;
                    color: #9e9e9e;
                    horizontal-alignment: center;
                }
            }
        }
    }
}
