import { Button, VerticalBox, HorizontalBox, ListView, LineEdit, Switch, ComboBox, ScrollView } from "std-widgets.slint";

struct ReminderItem {
    id: int,
    title: string,
    content: string,
    enabled: bool,
    completed: bool,
    next-trigger: string,
}

export component MainWindow inherits Window {
    title: "due";
    min-width: 800px;
    min-height: 500px;
    preferred-width: 960px;
    preferred-height: 600px;

    // 回调
    callback add-clicked(string, string);
    callback delete-clicked(int);
    callback toggle-enabled(int);
    callback select-reminder(int);
    callback save-clicked(int, string, string, int, string, string, string, string, string);

    // 列表数据
    in-out property <[ReminderItem]> reminders: [];
    in-out property <int> selected-index: -1;

    // 编辑面板字段
    in-out property <string> edit-title: "";
    in-out property <string> edit-content: "";
    in-out property <int> repeat-type-index: 0;
    in-out property <string> edit-start-date: "";
    in-out property <string> edit-end-date: "";
    in-out property <string> edit-daily-start: "";
    in-out property <string> edit-daily-end: "";
    in-out property <string> repeat-amount-value: "";
    in-out property <string> repeat-limit-value: "";

    // 暖灰主色调
    background: #f5f0eb;

    HorizontalLayout {
        spacing: 0px;

        // ── 左侧：提醒列表 ──
        Rectangle {
            width: 320px;
            background: #faf7f3;

            VerticalLayout {
                padding: 20px;
                spacing: 16px;

                // 标题
                Text {
                    text: "due";
                    font-size: 28px;
                    font-weight: 700;
                    color: #3d3530;
                    horizontal-alignment: left;
                }

                // 添加提醒
                HorizontalLayout {
                    spacing: 8px;
                    height: 36px;

                    new-title := LineEdit {
                        placeholder-text: "新提醒标题...";
                        horizontal-stretch: 1;
                    }

                    Button {
                        text: "+";
                        width: 36px;
                        clicked => {
                            if (new-title.text != "") {
                                root.add-clicked(new-title.text, "");
                                new-title.text = "";
                            }
                        }
                    }
                }

                // 提醒列表（可滚动）
                ListView {
                    for item[id] in root.reminders: Rectangle {
                        height: 56px;
                        border-radius: 10px;
                        background: id == root.selected-index ? #fff5ee : transparent;

                        TouchArea {
                            clicked => {
                                root.select-reminder(id);
                            }
                        }

                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 8px;
                            spacing: 8px;
                            alignment: stretch;

                            // 状态指示
                            Rectangle {
                                width: 8px;
                                border-radius: 4px;
                                y: parent.height / 2 - self.height / 2;
                                height: 24px;
                                background: item.completed ? #a8b5a0 : (item.enabled ? #e8956a : #c5bfb8);
                            }

                            VerticalLayout {
                                alignment: center;
                                spacing: 2px;

                                Text {
                                    text: item.title;
                                    font-size: 14px;
                                    font-weight: 600;
                                    color: item.completed ? #b0a89e : #3d3530;
                                    overflow: elide;
                                }

                                Text {
                                    text: item.next-trigger;
                                    font-size: 11px;
                                    color: #9e958c;
                                    visible: item.next-trigger != "";
                                }
                            }

                            // 启用/禁用
                            Switch {
                                checked: item.enabled;
                                width: 40px;
                                toggled => {
                                    root.toggle-enabled(id);
                                }
                            }
                        }
                    }
                }
            }
        }

        // ── 右侧：详情编辑 ──
        Rectangle {
            background: #ffffff;

            if root.selected-index >= 0 && root.selected-index < root.reminders.length: ScrollView {
                VerticalLayout {
                    padding: 32px;
                    spacing: 20px;

                    Text {
                        text: "编辑提醒";
                        font-size: 20px;
                        font-weight: 700;
                        color: #3d3530;
                    }

                    // 标题
                    VerticalLayout {
                        spacing: 6px;
                        Text {
                            text: "标题";
                            font-size: 12px;
                            color: #9e958c;
                        }
                        edit-title-input := LineEdit {
                            text: root.edit-title;
                            height: 36px;
                        }
                    }

                    // 内容
                    VerticalLayout {
                        spacing: 6px;
                        Text {
                            text: "内容";
                            font-size: 12px;
                            color: #9e958c;
                        }
                        edit-content-input := LineEdit {
                            text: root.edit-content;
                            height: 36px;
                        }
                    }

                    // 分隔
                    Rectangle { height: 1px; background: #ede8e3; }

                    // 重复设置
                    Text {
                        text: "重复设置";
                        font-size: 16px;
                        font-weight: 600;
                        color: #3d3530;
                    }

                    // 重复类型
                    VerticalLayout {
                        spacing: 6px;
                        Text {
                            text: "重复类型";
                            font-size: 12px;
                            color: #9e958c;
                        }
                        repeat-combo := ComboBox {
                            model: ["不重复", "按分钟", "按小时", "按天"];
                            current-index: root.repeat-type-index;
                            selected => {
                                root.repeat-type-index = self.current-index;
                            }
                        }
                    }

                    // 重复间隔（类型不为"不重复"时显示）
                    if root.repeat-type-index > 0: VerticalLayout {
                        spacing: 6px;
                        Text {
                            text: root.repeat-type-index == 1 ? "间隔（分钟）" : (root.repeat-type-index == 2 ? "间隔（小时）" : "间隔（天）");
                            font-size: 12px;
                            color: #9e958c;
                        }
                        repeat-amount-input := LineEdit {
                            text: root.repeat-amount-value;
                            placeholder-text: "例如: 30";
                            height: 36px;
                            input-type: number;
                            edited => {
                                root.repeat-amount-value = self.text;
                            }
                        }
                    }

                    // 重复次数限制
                    if root.repeat-type-index > 0: VerticalLayout {
                        spacing: 6px;
                        Text {
                            text: "次数限制（留空不限）";
                            font-size: 12px;
                            color: #9e958c;
                        }
                        repeat-limit-input := LineEdit {
                            text: root.repeat-limit-value;
                            placeholder-text: "不限";
                            height: 36px;
                            input-type: number;
                            edited => {
                                root.repeat-limit-value = self.text;
                            }
                        }
                    }

                    // 分隔
                    Rectangle { height: 1px; background: #ede8e3; }

                    // 日期范围
                    Text {
                        text: "日期范围";
                        font-size: 16px;
                        font-weight: 600;
                        color: #3d3530;
                    }

                    HorizontalLayout {
                        spacing: 12px;

                        VerticalLayout {
                            horizontal-stretch: 1;
                            spacing: 6px;
                            Text {
                                text: "开始日期";
                                font-size: 12px;
                                color: #9e958c;
                            }
                            start-date-input := LineEdit {
                                text: root.edit-start-date;
                                placeholder-text: "2026-06-01";
                                height: 36px;
                            }
                        }

                        VerticalLayout {
                            horizontal-stretch: 1;
                            spacing: 6px;
                            Text {
                                text: "结束日期";
                                font-size: 12px;
                                color: #9e958c;
                            }
                            end-date-input := LineEdit {
                                text: root.edit-end-date;
                                placeholder-text: "2026-12-31";
                                height: 36px;
                            }
                        }
                    }

                    // 分隔
                    Rectangle { height: 1px; background: #ede8e3; }

                    // 每日时间窗口
                    Text {
                        text: "每日活跃时段";
                        font-size: 16px;
                        font-weight: 600;
                        color: #3d3530;
                    }

                    HorizontalLayout {
                        spacing: 12px;

                        VerticalLayout {
                            horizontal-stretch: 1;
                            spacing: 6px;
                            Text {
                                text: "开始时间";
                                font-size: 12px;
                                color: #9e958c;
                            }
                            daily-start-input := LineEdit {
                                text: root.edit-daily-start;
                                placeholder-text: "09:00";
                                height: 36px;
                            }
                        }

                        VerticalLayout {
                            horizontal-stretch: 1;
                            spacing: 6px;
                            Text {
                                text: "结束时间";
                                font-size: 12px;
                                color: #9e958c;
                            }
                            daily-end-input := LineEdit {
                                text: root.edit-daily-end;
                                placeholder-text: "18:00";
                                height: 36px;
                            }
                        }
                    }

                    // 弹性空白
                    Rectangle { vertical-stretch: 1; }

                    // 操作按钮
                    HorizontalLayout {
                        spacing: 12px;

                        Button {
                            text: "保存修改";
                            horizontal-stretch: 1;
                            clicked => {
                                root.save-clicked(
                                    root.selected-index,
                                    edit-title-input.text,
                                    edit-content-input.text,
                                    root.repeat-type-index,
                                    root.repeat-type-index > 0 ? root.repeat-amount-value : "",
                                    start-date-input.text,
                                    end-date-input.text,
                                    daily-start-input.text,
                                    daily-end-input.text,
                                );
                            }
                        }

                        Button {
                            text: "删除提醒";
                            horizontal-stretch: 0;
                            clicked => {
                                root.delete-clicked(root.selected-index);
                            }
                        }
                    }
                }
            }

            if root.selected-index < 0 || root.selected-index >= root.reminders.length: VerticalLayout {
                alignment: center;
                spacing: 8px;

                Text {
                    text: "选择一个提醒";
                    font-size: 16px;
                    color: #c5bfb8;
                }
                Text {
                    text: "或创建新提醒开始";
                    font-size: 13px;
                    color: #d9d3cc;
                }
            }
        }
    }
}
